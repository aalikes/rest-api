PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Notion Integration ─────────────────────────────────────────────
# Get token at: https://www.notion.so/my-integrations
NOTION_TOKEN=

# Notion Database IDs (32-char hex from database URL)
# Create databases in Notion, share with your integration, then paste IDs here
NOTION_TASKS_DB_ID=
NOTION_FINANCIALS_DB_ID=
NOTION_READING_DB_ID=
NOTION_DASHBOARD_PAGE_ID=

# ── Coinbase Integration ────────────────────────────────────────────
# Get keys at: https://portal.cdp.coinbase.com/access/api
COINBASE_API_KEY_NAME=
COINBASE_API_PRIVATE_KEY=
